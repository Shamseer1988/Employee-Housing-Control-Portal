# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.local
.pytest_cache/
.coverage

# Flask / Alembic
instance/
backend/migrations/versions/*.pyc

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env
frontend/.env
frontend/.env.local
frontend/.env.production
backend/.env

# Uploads & backups (keep folder, ignore contents)
uploads/*
!uploads/.gitkeep
backups/*
!backups/.gitkeep

# IDE
.idea/
.vscode/
*.swp
backend/.venv-test/

# Production TLS material — never commit (Phase 11).
# Track only the README + layout templates; the real origin.crt /
# origin.key are operator-placed at deploy time.
deploy/ssl/*
!deploy/ssl/README.txt
!deploy/ssl/origin.crt.example
!deploy/ssl/origin.key.example
