# Root .env loaded by docker-compose. Copy to .env and fill in.

POSTGRES_DB=pug_accommodation
POSTGRES_USER=pug
POSTGRES_PASSWORD=change-me-please

SECRET_KEY=generate-a-long-random-string
JWT_SECRET_KEY=generate-another-long-random-string-32-bytes-min

# Comma-separated origins allowed for the browser SPA. When running behind
# nginx on the same host this matches the public URL.
CORS_ORIGINS=http://localhost

# What the browser uses to reach the API (and what Next.js bakes into the
# build via NEXT_PUBLIC_API_URL).
PUBLIC_BASE_URL=http://localhost

# Default super user, created/refreshed on every container start.
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!

HTTP_PORT=80
GUNICORN_WORKERS=4
