# Root .env loaded by docker-compose. Copy to .env and fill in the
# required secrets at the top. Everything else has sensible defaults.

# -------- Database (required) --------
POSTGRES_DB=pug_accommodation
POSTGRES_USER=pug
POSTGRES_PASSWORD=change-me-please

# -------- App secrets (required, min 32 bytes each) --------
# Generate with: openssl rand -hex 32
SECRET_KEY=generate-a-long-random-string-32-bytes-or-more
JWT_SECRET_KEY=generate-another-long-random-string-32-bytes-or-more

# -------- Default super user (created on first boot) --------
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!

# -------- Network --------
HTTP_PORT=80
HTTPS_PORT=443
GUNICORN_WORKERS=4

# -------- Public origin (Cloudflare → nginx → here) --------
# Used for absolute URLs in emails and any redirect / OAuth flows.
PUBLIC_BASE_URL=https://housing.example.com

# CORS: Same-origin requests through nginx (the typical case — the bundle
# calls /api/* on the same host that served the page) DO NOT trigger
# CORS at all.
#
# PRODUCTION REQUIREMENT: list explicit origins. "*" is rejected at
# boot by ProductionConfig.validate(). For the single-host Cloudflare
# deployment described in DEPLOY.md set this to your actual URL.
CORS_ORIGINS=https://housing.example.com

# Optional: only set if the frontend bundle is served from a different
# origin than the API. The standard same-host deployment leaves this
# blank so the bundle uses relative /api URLs.
PUBLIC_API_URL=

# -------- Redis (Phase 2 / 5 / 6 / 8) --------
# Backs rate-limiting, the Celery broker, SSE fan-out, and optional
# metrics aggregation. Without REDIS_URL the rate limiter falls back to
# in-memory storage — fine for single-process dev but each gunicorn
# worker would have its own counters. Always set this for prod.
REDIS_URL=redis://redis:6379/0

# -------- Observability (Phase 6) --------
# Sentry DSN — when unset, init_sentry() is a no-op.
SENTRY_DSN=
# Shared secret a Prometheus scraper must echo as X-Metrics-Token to
# read /metrics. Leave empty when the scraper is on a private network.
METRICS_TOKEN=
# JSON access logs default on in production. Override here if needed.
LOG_LEVEL=INFO
# Frontend: optional Sentry browser-SDK DSN (read at build time).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production

# -------- Cloudflare Origin Certificate (Phase 11) --------
# Place the cert + key here on the host:
#     deploy/ssl/origin.pem  (chain)
#     deploy/ssl/origin.key  (0600 on the key)
# See deploy/ssl/README.txt and DEPLOY.md for the full runbook.

# -------- API docs (Phase 4) --------
# /openapi.json and /docs (Swagger UI) are off in production unless
# this flag is explicitly truthy.
ENABLE_API_DOCS=
