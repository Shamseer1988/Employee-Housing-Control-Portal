# Root .env loaded by docker-compose. Copy to .env and fill in the
# 4 required secrets at the top. Everything else has sensible defaults.

# -------- Database (required) --------
POSTGRES_DB=pug_accommodation
POSTGRES_USER=pug
POSTGRES_PASSWORD=change-me-please

# -------- App secrets (required) --------
SECRET_KEY=generate-a-long-random-string
JWT_SECRET_KEY=generate-another-long-random-string-32-bytes-min

# -------- Default super user (created on first boot) --------
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!

# -------- Network --------
HTTP_PORT=80
GUNICORN_WORKERS=4

# CORS: Same-origin requests through nginx (the common case — you access
# the portal on http://<host>/ and the bundle calls /api/* on the same
# host) DO NOT trigger CORS at all. You only need entries here when the
# backend is hit from a different origin, e.g. native `npm run dev`
# against this dockerized backend.
#
# PRODUCTION REQUIREMENT: list explicit origins. "*" is rejected at
# boot by ProductionConfig.validate(). For a single-host deployment
# set this to your real URL, e.g. https://housing.example.com.
CORS_ORIGINS=http://localhost:3000

# Redis: backs rate-limiting in Phase 2 and (later) the Celery broker,
# SSE fan-out, and notification cache. Without REDIS_URL the rate
# limiter falls back to in-memory storage — fine for single-process
# dev, but each gunicorn worker would then have its own counters in
# production. Always set this for prod.
REDIS_URL=redis://redis:6379/0

# The frontend bundle uses RELATIVE API URLs by default, so the portal
# works at http://localhost/, http://<your-lan-ip>/, http://tailscale-name/
# and any other hostname without rebuilding. Set PUBLIC_API_URL only if
# the API lives on a different origin than the page.
# Example: PUBLIC_API_URL=https://api.pug.example.com
PUBLIC_API_URL=
