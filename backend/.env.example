# =============================================================================
# backend/.env — single source of truth for the bare-metal deployment.
#
#     cp backend/.env.example backend/.env       (or copy on Windows)
#
# Loaded automatically by config.py at backend boot via python-dotenv.
# Any value the operator exports in the shell BEFORE running the
# backend wins over what's in this file (override=False in code).
# =============================================================================

# -------- Flask --------
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1

# -------- App secrets (change for anything internet-facing) --------
# Generate strong values:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-key-change-in-production-12345
JWT_SECRET_KEY=jwt-dev-secret-change-in-production-67890

# -------- Database --------
# Point at the PostgreSQL 17 install on this host.
POSTGRES_DB=pug_accommodation
POSTGRES_USER=pug
POSTGRES_PASSWORD=pug_local_dev_pw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: full URL overrides the assembled one entirely.
# DATABASE_URL=postgresql+psycopg2://pug:pug_local_dev_pw@localhost:5432/pug_accommodation

# -------- Redis --------
# On Windows: Memurai or WSL2-Redis. See docs/BARE_METAL_WINDOWS.md.
# On Linux/macOS: redis-server from your package manager.
REDIS_URL=redis://localhost:6379/0

# -------- Auth cookies --------
# Dev runs plain HTTP, so cookies must NOT be Secure or the browser drops
# them. Production behind TLS sets JWT_COOKIE_SECURE=true.
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

# -------- CORS --------
# '*' is fine in dev. Production must list explicit origins (the
# ProductionConfig boot check rejects '*').
CORS_ORIGINS=*

# -------- Uploads + backups (host paths) --------
# Relative paths are resolved against backend/. Use absolute paths in
# production (e.g. C:\Apps\housing-uploads on Windows, /var/lib/housing/
# on Linux).
UPLOAD_FOLDER=../uploads
BACKUP_FOLDER=../backups
MAX_CONTENT_LENGTH_MB=25

# -------- Default super user (created/refreshed by `flask seed`) --------
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!

# -------- waitress (production WSGI) --------
# Adjust threads for your hardware. Bind address depends on deployment
# topology — see docs/FRESH_DEPLOY_LXC.md vs docs/FRESH_DEPLOY_LXC_EDGE.md:
#   Topology A — self-contained CT (nginx in this same host/CT):
#       WAITRESS_LISTEN=127.0.0.1:5000   <-- safe default
#   Topology B — shared edge-nginx CT (separate reverse-proxy host):
#       WAITRESS_LISTEN=0.0.0.0:5000     <-- needed so the edge can reach us
#                                            ALSO firewall :5000 to the edge IP
WAITRESS_LISTEN=127.0.0.1:5000
WAITRESS_THREADS=8
