# =============================================================================
# backend/.env  — single source of truth for the LOCAL docker stack.
#
#   cp backend/.env.example backend/.env
#
# The db, backend, worker and beat services all load THIS file (see
# docker-compose.yml `env_file`). Postgres initdb and the app read the
# same POSTGRES_* values, so credentials match by construction.
#
# Native (non-Docker) dev also works: set POSTGRES_HOST=localhost (or a
# full DATABASE_URL) below.
# =============================================================================

# -------- Flask --------
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1

# -------- App secrets (change for anything internet-facing) --------
SECRET_KEY=dev-secret-key-change-in-production-12345
JWT_SECRET_KEY=jwt-dev-secret-change-in-production-67890

# -------- Database --------
# The backend assembles its connection string from these POSTGRES_*
# values (backend/config.py _database_uri). Inside Docker the compose
# file forces POSTGRES_HOST=db; for native dev leave it as localhost.
POSTGRES_DB=pug_accommodation
POSTGRES_USER=pug
POSTGRES_PASSWORD=pug_local_dev_pw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: set a full URL to override the assembled one entirely.
# DATABASE_URL=postgresql+psycopg2://pug:pug_local_dev_pw@localhost:5432/pug_accommodation

# -------- Redis --------
REDIS_URL=redis://localhost:6379/0

# -------- Auth cookies --------
# LOCAL is plain HTTP, so cookies must NOT be Secure or the browser drops
# them. The prod compose sets these to true / Lax over HTTPS.
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

# -------- CORS --------
# '*' is fine locally (same-origin through the Next proxy anyway). Prod
# rejects '*' at boot — list explicit origins there.
CORS_ORIGINS=*

# -------- Uploads --------
UPLOAD_FOLDER=../uploads
MAX_CONTENT_LENGTH_MB=25

# -------- Default super user (created/refreshed by `flask seed`) --------
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!
