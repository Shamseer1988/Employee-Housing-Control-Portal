FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pug_accommodation

CORS_ORIGINS=http://localhost:3000

UPLOAD_FOLDER=../uploads
MAX_CONTENT_LENGTH_MB=25

# Default super user (created/refreshed by `flask --app wsgi seed`)
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@pugroup.local
SUPERUSER_PASSWORD=ChangeMe123!
