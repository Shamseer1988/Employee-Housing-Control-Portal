# =============================================================================
# frontend/.env.runtime — runtime config for `next start` under systemd.
#
#     cp frontend/.env.runtime.example frontend/.env.runtime
#
# Read by deploy/systemd/housing-frontend.service via EnvironmentFile=-.
# The `-` makes it optional: if you delete the file the unit falls back
# to topology-A defaults baked into ExecStart. So you only need to copy
# this file when you actually want to change something — most operators
# touch it once to flip HOSTNAME for topology B and never again.
#
# This is NOT the build-time env file. Build-time vars (the
# NEXT_PUBLIC_* family) belong in frontend/.env or frontend/.env.local
# and are baked into `npm run build` output.
# =============================================================================

# Production runtime. Don't change unless you're profiling.
NODE_ENV=production

# Bind address — picks deployment topology:
#   Topology A — self-contained CT (nginx in this same host/CT):
#       HOSTNAME=127.0.0.1               <-- safe default
#   Topology B — shared edge-nginx CT (separate reverse-proxy host):
#       HOSTNAME=0.0.0.0                 <-- needed so the edge can reach us
#                                            ALSO firewall :3000 to the edge IP
HOSTNAME=127.0.0.1

# Next.js listen port. Match the upstream in your nginx site config.
PORT=3000
